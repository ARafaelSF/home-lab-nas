# Copiar para duplicati-ha.env no mesmo diretório (/opt/duplicati-scripts no host).
# Não commitar duplicati-ha.env (pode conter token).

HA_URL="http://192.168.3.10:8123"

# Modo de notificação:
#   webhook — POST /api/webhook/duplicati_backup_result (padrão, sem token, local_only na automação)
#   event   — POST /api/events/duplicati_backup_result (requer HA_TOKEN)
#   both    — webhook + event
HA_NOTIFY_MODE="webhook"

# Long-Lived Token (opcional; só para modo event ou both)
# HA_TOKEN=""

# Log (dentro do container: /scripts/duplicati_to_ha.log)
# LOG_FILE="/scripts/duplicati_to_ha.log"
